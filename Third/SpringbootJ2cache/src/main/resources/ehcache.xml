<?xml version="1.0" encoding="UTF-8"?>
<ehcache>

    <!-- 默认缓存配置 -->
    <defaultCache
            maxElementsInMemory="1000"
            eternal="false"
            timeToIdleSeconds="600"
            timeToLiveSeconds="600"
            overflowToDisk="false"/>

    <!-- book缓存 -->
    <cache name="book"
           maxElementsInMemory="1000"
           eternal="false"
           timeToIdleSeconds="600"
           timeToLiveSeconds="600"
           overflowToDisk="false"/>

</ehcache>